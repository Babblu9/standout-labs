---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Every .md file in this folder becomes a post automatically.
const modules = import.meta.glob<{ url: string; frontmatter: { title: string; description: string; pubDate: string } }>('./*.md', { eager: true });
const posts = Object.values(modules).sort(
  (a, b) => new Date(b.frontmatter.pubDate).valueOf() - new Date(a.frontmatter.pubDate).valueOf()
);

const title = "Blog — Digital Marketing & AI Branding Insights | Standout Labs";
const description =
  "Guides and insights on digital marketing, AI branding, web design, and growth for businesses in Hyderabad — from the Standout Labs studio.";
---

<Layout title={title} description={description} canonical="/blog/">
  <Header />

  <!-- HERO -->
  <section class="relative w-full bg-brand-black text-brand-white overflow-hidden">
    <div class="absolute inset-0 blueprint-bg opacity-40 pointer-events-none"></div>
    <div class="absolute -top-24 -right-24 w-[32rem] h-[32rem] rounded-full bg-brand-blue/20 blur-[120px] pointer-events-none"></div>
    <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-12 py-24 md:py-32 flex flex-col gap-6">
      <h1 class="font-display font-bold text-4xl sm:text-6xl md:text-7xl leading-[0.95] tracking-tight text-balance max-w-4xl">
        Insights on growth,<br class="hidden md:block" /> <span class="text-brand-blue">built in Hyderabad.</span>
      </h1>
      <p class="text-white/70 text-lg md:text-xl leading-relaxed max-w-2xl font-sans">
        Practical guides on digital marketing, AI branding, web design, and growth — for founders and businesses in Hyderabad and beyond.
      </p>
    </div>
  </section>

  <!-- POST LIST -->
  <section class="w-full bg-brand-bg">
    <div class="w-full max-w-4xl mx-auto px-6 md:px-12 py-16 md:py-24">
      {posts.length === 0 ? (
        <p class="text-neutral-700 font-sans">New articles coming soon.</p>
      ) : (
        <div class="flex flex-col">
          {posts.map((post, i) => (
            <a
              href={post.url}
              class={`group flex flex-col gap-3 py-8 ${i !== 0 ? 'border-t border-[#E3E3DF]' : ''} cursor-none`}
            >
              <time class="text-xs font-semibold uppercase tracking-widest text-brand-blue" datetime={new Date(post.frontmatter.pubDate).toISOString()}>
                {new Date(post.frontmatter.pubDate).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h2 class="font-display font-bold text-2xl md:text-3xl text-brand-black tracking-tight leading-[1.1] group-hover:text-brand-blue transition-colors text-balance">
                {post.frontmatter.title}
              </h2>
              <p class="text-neutral-700 text-base leading-relaxed font-sans max-w-2xl">{post.frontmatter.description}</p>
              <span class="text-sm font-semibold text-brand-black inline-flex items-center gap-1.5 group-hover:text-brand-blue transition-colors">Read article →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <Footer />
</Layout>
