---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import ScrollStory from '../components/ScrollStory.tsx';
import WhatWeDo from '../components/WhatWeDo.astro';
import SplitStory from '../components/SplitStory.tsx';
import HorizontalPortfolio from '../components/HorizontalPortfolio.tsx';
import BlueprintProcess from '../components/BlueprintProcess.tsx';
import WhyStandout from '../components/WhyStandout.astro';
import Testimonials from '../components/Testimonials.astro';
import Footer from '../components/Footer.astro';
import LiveAIDemo from '../components/LiveAIDemo.tsx';
---

<Layout>
  {/* Sticky nav with scroll-progress logo */}
  <Header />

  {/* Interactive grid hero — who we are, in one screen */}
  <Hero />

  {/* Transformation hook: blend in → stand out */}
  <ScrollStory client:load />

  {/* What we do — the six growth systems */}
  <WhatWeDo />

  {/* How the systems connect — AI workflow */}
  <SplitStory client:load />

  {/* Proof: selected work */}
  <HorizontalPortfolio client:load />

  {/* How we work — blueprint process */}
  <BlueprintProcess client:load />

  {/* Why choose us — philosophy */}
  <WhyStandout />

  {/* Client results */}
  <Testimonials />

  {/* Closing CTA + contact */}
  <Footer />

  {/* Floating assistant demo */}
  <LiveAIDemo client:load />
</Layout>
