---
import Logo from './Logo.tsx';
import MagneticButton from './MagneticButton.tsx';
---

<footer id="contact" class="w-full bg-brand-bg relative overflow-hidden border-t border-[#E3E3DF]/50 scroll-mt-20">
  {/* Dot Grid Background */}
  <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>

  <div class="w-full max-w-7xl mx-auto px-6 md:px-12 py-24 md:py-32 flex flex-col gap-24 relative z-10">
    
    {/* Final CTA block */}
    <div class="flex flex-col items-center text-center gap-6 md:gap-8">
      {/* Premium logo directly above CTA */}
      <div class="mb-2">
        <Logo client:load size={64} />
      </div>

      <h2 class="font-display font-bold text-5xl sm:text-7xl md:text-8xl lg:text-[110px] leading-[0.9] tracking-tight text-brand-black max-w-4xl">
        Ready to <br class="sm:hidden"/>stand out?
      </h2>
      
      <MagneticButton 
        client:load 
        className="bg-brand-blue hover:bg-brand-black text-brand-white text-base md:text-lg font-semibold px-10 py-5 rounded-full transition-all duration-300 shadow-md hover:shadow-lg cursor-none animate-bounce-slow"
        onClick={() => {
          window.location.href = 'mailto:info@standoutlabs.in';
        }}
      >
        Start Your Project <span class="inline-block ml-1">→</span>
      </MagneticButton>
    </div>

    {/* Footer Bottom Metadata and Links */}
    <div class="flex flex-col lg:flex-row justify-between items-start gap-12 border-t border-[#E3E3DF] pt-12">
      
      {/* Brand logo & tagline */}
      <div class="flex flex-col gap-2 text-left max-w-xs">
        <div class="flex items-center gap-2.5">
          <Logo client:load size={24} interactive={false} />
          <span class="font-display font-bold text-xl text-brand-black tracking-tight">
            Standout<span class="text-brand-blue">Labs</span>
          </span>
        </div>
        <span class="text-[11px] font-semibold uppercase tracking-wider text-neutral-600">
          We make brands impossible to ignore.
        </span>
        <span class="text-[11px] text-neutral-600 mt-2 font-sans">
          © 2026 Standout Labs. All rights reserved.
        </span>
      </div>

      {/* Footer Nav */}
      <div class="flex flex-col gap-3.5 text-left font-sans">
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-600/60">Explore</span>
        <div class="flex flex-col gap-2 text-xs">
          <a href="/services/" class="font-medium text-neutral-600 hover:text-brand-black cursor-none">Services</a>
          <a href="/#work" class="font-medium text-neutral-600 hover:text-brand-black cursor-none">Work</a>
          <a href="/process/" class="font-medium text-neutral-600 hover:text-brand-black cursor-none">Process</a>
          <a href="/blog/" class="font-medium text-neutral-600 hover:text-brand-black cursor-none">Blog</a>
          <a href="/#why-choose-us" class="font-medium text-neutral-600 hover:text-brand-black cursor-none">Why Us</a>
        </div>
      </div>

      {/* Contact Details */}
      <div class="flex flex-col gap-3.5 text-left font-sans">
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-neutral-600/60">Connect</span>
        <div class="flex flex-col gap-2 text-xs">
          <a href="mailto:info@standoutlabs.in" class="font-medium text-brand-black hover:text-brand-blue cursor-none">info@standoutlabs.in</a>
          <a href="tel:+919963491075" class="font-medium text-neutral-600 hover:text-brand-blue cursor-none">+91 99634 91075</a>
          <a href="tel:8374930568" class="font-medium text-neutral-600 hover:text-brand-blue cursor-none">8374930568</a>
        </div>

        {/* Social icons */}
        <div class="flex items-center gap-3 mt-1">
          <a href="https://www.linkedin.com/company/standoutlabs" target="_blank" rel="noopener noreferrer" aria-label="Standout Labs on LinkedIn" class="w-8 h-8 rounded-full border border-[#E3E3DF] grid place-items-center text-neutral-600 hover:text-brand-blue hover:border-brand-blue/40 transition-colors cursor-none">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
          </a>
          <a href="https://www.instagram.com/standoutlabs" target="_blank" rel="noopener noreferrer" aria-label="Standout Labs on Instagram" class="w-8 h-8 rounded-full border border-[#E3E3DF] grid place-items-center text-neutral-600 hover:text-brand-blue hover:border-brand-blue/40 transition-colors cursor-none">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 0 1-1.38-.9 3.7 3.7 0 0 1-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zM12 0C8.74 0 8.33.01 7.05.07c-1.28.06-2.15.26-2.91.56-.79.31-1.46.72-2.13 1.38A5.9 5.9 0 0 0 .63 4.14c-.3.76-.5 1.63-.56 2.91C.01 8.33 0 8.74 0 12s.01 3.67.07 4.95c.06 1.28.26 2.15.56 2.91.31.79.72 1.46 1.38 2.13.67.66 1.34 1.07 2.13 1.38.76.3 1.63.5 2.91.56C8.33 23.99 8.74 24 12 24s3.67-.01 4.95-.07c1.28-.06 2.15-.26 2.91-.56a5.9 5.9 0 0 0 2.13-1.38 5.9 5.9 0 0 0 1.38-2.13c.3-.76.5-1.63.56-2.91.06-1.28.07-1.69.07-4.95s-.01-3.67-.07-4.95c-.06-1.28-.26-2.15-.56-2.91a5.9 5.9 0 0 0-1.38-2.13A5.9 5.9 0 0 0 19.86.63c-.76-.3-1.63-.5-2.91-.56C15.67.01 15.26 0 12 0zm0 5.84a6.16 6.16 0 1 0 0 12.32 6.16 6.16 0 0 0 0-12.32zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm7.85-10.41a1.44 1.44 0 1 1-2.88 0 1.44 1.44 0 0 1 2.88 0z"/></svg>
          </a>
          <a href="https://www.facebook.com/share/1EM7wJ1EbB/" target="_blank" rel="noopener noreferrer" aria-label="Standout Labs on Facebook" class="w-8 h-8 rounded-full border border-[#E3E3DF] grid place-items-center text-neutral-600 hover:text-brand-blue hover:border-brand-blue/40 transition-colors cursor-none">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07c0 6.03 4.39 11.03 10.13 11.93v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
          </a>
        </div>
      </div>

    </div>
  </div>
</footer>
