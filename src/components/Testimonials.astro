---
// Real clients + factual descriptions of what we built. No invented quotes.
// Swap any entry for a real client quote (add `quote` + `author`) when you have one.
const clients = [
  {
    name: "OnEasy — Fina AI",
    sector: "AI SaaS · Fintech",
    line: "An AI financial-model builder that turns a business idea into a complete, formula-driven model in seconds.",
    url: "https://oneasy-hazel.vercel.app",
  },
  {
    name: "Vishala Shopping Mall",
    sector: "Retail · Internal Systems",
    line: "A secure daily counter-closing and bookkeeping portal with role-based access and full audit logging across branches.",
    url: "https://vishalashoppingmalls-counterflow.vercel.app",
  },
  {
    name: "Aurelius Academy",
    sector: "Education · Hyderabad",
    line: "A premium brand landing site for a global-studies academy — SAT, IELTS, AP, and university admissions.",
    url: "https://aureliua.vercel.app",
  },
  {
    name: "NearLead",
    sector: "Growth · Lead Generation",
    line: "A local-business lead engine that finds, dedupes, enriches, and tracks outreach — from search to CRM.",
    url: "https://nearlead.vercel.app",
  },
];
---

<section class="w-full py-24 md:py-36 px-6 md:px-12 bg-white border-b border-[#E3E3DF]/50">
  <div class="w-full max-w-7xl mx-auto flex flex-col gap-14 md:gap-20">

    <div class="flex flex-col gap-5 max-w-3xl">
      <h2 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight text-brand-black leading-[0.95] text-balance">
        Businesses we've built for
      </h2>
      <p class="text-neutral-700 text-lg leading-relaxed font-sans">
        Real products, live in the wild — from AI SaaS to retail operations and lead generation.
        Every one is a system we designed, built, and shipped.
      </p>
    </div>

    {/* Client roster */}
    <div class="grid grid-cols-1 md:grid-cols-2 border-t border-l border-[#E3E3DF]">
      {clients.map((c) => (
        <a
          href={c.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col gap-3 p-8 md:p-10 border-b border-r border-[#E3E3DF] hover:bg-brand-bg transition-colors cursor-none"
        >
          <div class="flex items-baseline justify-between gap-4">
            <h3 class="font-display font-bold text-2xl md:text-3xl text-brand-black tracking-tight group-hover:text-brand-blue transition-colors">
              {c.name}
            </h3>
            <span class="text-neutral-400 text-lg group-hover:text-brand-blue transition-colors">↗</span>
          </div>
          <span class="text-xs font-semibold uppercase tracking-widest text-brand-blue">{c.sector}</span>
          <p class="text-neutral-700 text-base leading-relaxed font-sans max-w-md">{c.line}</p>
        </a>
      ))}
    </div>

  </div>
</section>
