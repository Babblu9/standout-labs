---
// Real clients & products, factual descriptions of what we built. No invented quotes.
// Add `url` only where the deployment is public. Add a real quote later to upgrade an entry.
const clients = [
  {
    name: "OnEasy",
    sector: "AI Finance · Fintech",
    line: "An AI system that builds a company’s full financial model and unit-economics workbook from a single prompt — replacing hours of manual Excel work.",
    url: "https://www.oneasy.ai/",
  },
  {
    name: "Vishala Shopping Malls",
    sector: "Retail · Operations",
    line: "One portal to manage every counter’s daily closing, with role-based access and full audit logging — replacing manual spreadsheets.",
    url: "https://vishalashoppingmall.in",
  },
  {
    name: "beingWise",
    sector: "EdTech · Our Product",
    line: "An EAMCET counselling platform for 25,000+ students — builds the exact ordered web-options list to freeze, with a Decision Copilot that flags mistakes before you lock.",
    url: "https://bestcollegeindia.com/",
  },
  {
    name: "Aurelius Academy",
    sector: "Education · Hyderabad",
    line: "A premium brand landing site for a global-studies academy — SAT, IELTS, AP, and university admissions.",
    url: "https://aureliua.vercel.app",
  },
  {
    name: "Void Architects",
    sector: "Architecture · Design",
    line: "A premium digital showcase for a contemporary architecture and design studio, featuring immersive project portfolios and a custom 3D consultation booking flow.",
    url: "https://www.voidarchitects.space/",
  },
];
---

<section class="w-full py-24 md:py-36 px-6 md:px-12 bg-white border-b border-[#E3E3DF]/50">
  <div class="w-full max-w-7xl mx-auto flex flex-col gap-14 md:gap-20">

    <div class="flex flex-col gap-5 max-w-3xl">
      <h2 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight text-brand-black leading-[0.95] text-balance">
        Businesses we've built for
      </h2>
      <p class="text-neutral-700 text-lg leading-relaxed font-sans">
        Real products, live and in use — from AI finance and retail operations to admissions and lead generation.
        Every one is a system we designed, built, and shipped.
      </p>
    </div>

    {/* Client roster */}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 border-t border-l border-[#E3E3DF]">
      {clients.map((c) => {
        const Tag = c.url ? 'a' : 'div';
        return (
          <Tag
            href={c.url}
            target={c.url ? '_blank' : undefined}
            rel={c.url ? 'noopener noreferrer' : undefined}
            class={`group flex flex-col gap-3 p-8 md:p-10 border-b border-r border-[#E3E3DF] transition-colors ${c.url ? 'hover:bg-brand-bg cursor-none' : ''}`}
          >
            <div class="flex items-baseline justify-between gap-4">
              <h3 class="font-display font-bold text-2xl md:text-3xl text-brand-black tracking-tight group-hover:text-brand-blue transition-colors">
                {c.name}
              </h3>
              {c.url && <span class="text-neutral-400 text-lg group-hover:text-brand-blue transition-colors">↗</span>}
            </div>
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-blue">{c.sector}</span>
            <p class="text-neutral-700 text-base leading-relaxed font-sans max-w-md">{c.line}</p>
          </Tag>
        );
      })}

      {/* CTA cell */}
      <a
        href="mailto:info@standoutlabs.in"
        class="group flex flex-col justify-center gap-3 p-8 md:p-10 border-b border-r border-[#E3E3DF] bg-brand-black text-white hover:bg-brand-blue transition-colors cursor-none"
      >
        <h3 class="font-display font-bold text-2xl md:text-3xl tracking-tight">Your product, next.</h3>
        <span class="text-sm font-semibold text-white/90 inline-flex items-center gap-1.5">Start a project →</span>
      </a>
    </div>

  </div>
</section>
