---
const testimonials = [
  {
    quote: "Standout Labs completely reframed how our product is perceived. We aren't just another SaaS anymore—we feel like a category leader. The brand design alone justified the investment.",
    author: "Sarah Jenkins",
    role: "VP of Product",
    company: "Quantum.ai"
  },
  {
    quote: "We replaced our entire sales operations stack with their AI pipelines. What used to take three full-time reps now happens instantly in the background. The ROI was immediate.",
    author: "Marcus Vance",
    role: "Chief Operating Officer",
    company: "Apex Logistical"
  }
];
---

<section class="w-full py-24 md:py-36 px-6 md:px-12 bg-white border-b border-[#E3E3DF]/50">
  <div class="w-full max-w-7xl mx-auto flex flex-col gap-16 md:gap-24">
    
    {/* Section Header */}
    <span class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-blue">
      Client Feedback
    </span>

    {/* Testimonials Grid */}
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24">
      {testimonials.map((t) => (
        <div class="flex flex-col gap-8">
          <blockquote class="font-display font-medium text-2xl sm:text-3xl md:text-4xl leading-snug text-brand-black">
            “{t.quote}”
          </blockquote>
          
          <div class="flex flex-col gap-0.5">
            <span class="text-base font-bold text-brand-black">
              {t.author}
            </span>
            <span class="text-sm text-brand-gray">
              {t.role}, <span class="text-brand-blue font-medium">{t.company}</span>
            </span>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
