---
const projects = [
  {
    name: "Quantum Analytics",
    industry: "Fintech / SaaS",
    image: "/images/saas-interface.png",
    challenge: "The client's original dashboard looked like a generic admin template, which hurt trial-to-paid conversions because the interface lacked a premium, trustworthy feel.",
    solution: "We engineered a dark-mode data analytics suite featuring glowing web elements, custom chart animations, and a highly responsive grid layout.",
    result: "+42% trial conversion rate and named Web Design of the Month."
  },
  {
    name: "Aurelius Identity",
    industry: "High-End Investment / Real Estate",
    image: "/images/brand-strategy.png",
    challenge: "Bland marketing collateral made Aurelius blend into a crowded investment space, making it difficult to establish prestige and trust with high-net-worth investors.",
    solution: "Created a modular 3D visual identity, custom typography systems, and a clean, high-end editorial website that commands attention.",
    result: "$150M+ in new investment capital secured within 4 months of brand relaunch."
  },
  {
    name: "Apex Flow",
    industry: "Logistical Systems / Automation",
    image: "/images/ai-automation.png",
    challenge: "Losing dozens of hours a week manually copy-routing customer data, payment sheets, and CRM pipelines across multiple disconnected databases.",
    solution: "Built a fully autonomous AI data pipeline connecting Stripe, Salesforce, and client communication nodes with custom machine learning routers.",
    result: "95% of administrative routing automated, saving 34 operational hours per week."
  }
];
---

<section id="work" class="w-full py-24 md:py-32 px-6 md:px-12 bg-brand-bg border-b border-[#E3E3DF]/50 scroll-mt-20">
  <div class="w-full max-w-7xl mx-auto flex flex-col gap-16">
    
    {/* Section Header */}
    <div class="flex flex-col gap-4">
      <span class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-blue">
        Selected Work
      </span>
      <h2 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight text-brand-black max-w-2xl leading-[0.95]">
        We build brands people remember.
      </h2>
    </div>

    {/* Project List */}
    <div class="flex flex-col gap-24 md:gap-36">
      {projects.map((project) => (
        <div class="group flex flex-col gap-8 md:gap-12">
          {/* Huge screenshot container */}
          <div class="relative w-full rounded-2xl overflow-hidden border border-[#E3E3DF] shadow-[0_1px_3px_rgba(17,17,17,0.02),0_20px_50px_rgba(17,17,17,0.04)] bg-white cursor-none">
            <img 
              src={project.image} 
              alt={`${project.name} mockup`}
              class="w-full h-auto object-cover object-center transform transition-transform duration-700 ease-out group-hover:scale-[1.025]"
            />
          </div>

          {/* Project Details Grid */}
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 pt-4">
            {/* Left Col: Name and Industry */}
            <div class="lg:col-span-4 flex flex-col gap-2">
              <h3 class="font-display font-bold text-3xl md:text-4xl text-brand-black tracking-tight">
                {project.name}
              </h3>
              <span class="text-sm font-semibold tracking-wider text-brand-blue uppercase">
                {project.industry}
              </span>
            </div>

            {/* Right Col: Details */}
            <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8">
              {/* Challenge */}
              <div class="flex flex-col gap-2">
                <h4 class="text-xs font-semibold tracking-wider text-brand-black uppercase">
                  Challenge
                </h4>
                <p class="text-brand-gray text-sm md:text-base leading-relaxed">
                  {project.challenge}
                </p>
              </div>

              {/* Solution */}
              <div class="flex flex-col gap-2">
                <h4 class="text-xs font-semibold tracking-wider text-brand-black uppercase">
                  Solution
                </h4>
                <p class="text-brand-gray text-sm md:text-base leading-relaxed">
                  {project.solution}
                </p>
              </div>

              {/* Result */}
              <div class="flex flex-col gap-2">
                <h4 class="text-xs font-semibold tracking-wider text-brand-blue uppercase">
                  Result
                </h4>
                <p class="font-display font-medium text-brand-black text-sm md:text-base leading-relaxed">
                  {project.result}
                </p>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
