---
const stats = [
  { value: "50+", label: "Projects Delivered" },
  { value: "12", label: "Industries Served" },
  { value: "95%", label: "Client Satisfaction" },
  { value: "4X", label: "Average Growth Rate" }
];
---

<section class="w-full py-16 md:py-24 px-6 md:px-12 bg-white border-b border-[#E3E3DF]/50 z-10 relative">
  <div class="w-full max-w-7xl mx-auto">
    <div class="grid grid-cols-2 lg:grid-cols-4 divide-y lg:divide-y-0 lg:divide-x divide-[#E3E3DF]">
      {stats.map((stat, index) => (
        <div class={`flex flex-col gap-2 p-6 md:p-10 ${index % 2 === 0 ? 'pr-6 md:pr-10' : 'pl-6 md:pl-10'} lg:p-10 first:pl-0 last:pr-0`}>
          <span class="font-display font-bold text-5xl md:text-7xl text-brand-black tracking-tight select-none">
            {stat.value}
          </span>
          <span class="text-xs md:text-sm font-semibold uppercase tracking-wider text-brand-gray">
            {stat.label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>
