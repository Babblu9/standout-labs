---
const principles = [
  {
    title: "Remarkable Design",
    description: "In a world of stock templates and generic copy, custom aesthetics are your ultimate competitive advantage. We build visual systems that establish immediate trust and authority."
  },
  {
    title: "AI First Integration",
    description: "We embed artificial intelligence into the core of your workflows. Custom pipelines automate manual operational overhead, letting you scale output without expanding headcount."
  },
  {
    title: "Business Focus",
    description: "We don't build projects to win design accolades; we build them to win market share. Every decision, animation, and route is optimized for user conversion and customer demand."
  }
];
---

<section id="why-choose-us" class="w-full py-24 md:py-36 px-6 md:px-12 bg-brand-bg border-b border-[#E3E3DF]/50 scroll-mt-20">
  <div class="w-full max-w-7xl mx-auto flex flex-col gap-16 md:gap-24">
    
    {/* Headline Pitch */}
    <div class="flex flex-col gap-6 max-w-4xl">
      <span class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-blue">
        Our Philosophy
      </span>
      <h2 class="font-display font-bold text-4xl sm:text-6xl md:text-7xl lg:text-[76px] leading-[0.95] tracking-tight text-brand-black">
        Different isn't decoration. <br/>
        <span class="text-brand-gray/50">It's strategy.</span>
      </h2>
    </div>

    {/* Three Principles Column Grid */}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {principles.map((p, idx) => (
        <div class="flex flex-col gap-4 p-8 bg-white border border-[#E3E3DF] rounded-2xl shadow-[0_1px_2px_rgba(17,17,17,0.02)]">
          <span class="font-display font-medium text-brand-blue text-lg">
            0{idx + 1}
          </span>
          <h3 class="font-display font-bold text-2xl text-brand-black tracking-tight">
            {p.title}
          </h3>
          <p class="text-brand-gray text-base leading-relaxed">
            {p.description}
          </p>
        </div>
      ))}
    </div>

  </div>
</section>
