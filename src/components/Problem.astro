<section class="w-full py-24 md:py-36 px-6 md:px-12 bg-brand-bg relative overflow-hidden border-b border-[#E3E3DF]/50">
  <div class="absolute inset-0 grid-bg opacity-30 pointer-events-none"></div>

  <div class="w-full max-w-5xl mx-auto flex flex-col gap-12 relative z-10">
    {/* Microcopy header */}
    <span class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-blue">
      The Cost of Sameness
    </span>

    {/* Primary Problem Statement */}
    <div class="flex flex-col gap-4">
      <h2 class="font-display font-bold text-4xl sm:text-6xl md:text-7xl lg:text-[76px] leading-[0.95] tracking-tight text-brand-black max-w-4xl">
        Most brands look identical. <br/>
        <span class="text-brand-blue">That's expensive.</span>
      </h2>
    </div>

    {/* Narrative Subtext */}
    <div class="w-full grid grid-cols-1 md:grid-cols-12 gap-6 pt-6">
      <div class="md:col-start-5 md:col-span-8">
        <p class="font-display font-medium text-2xl sm:text-3xl md:text-4xl leading-tight text-brand-gray/80">
          Your competitors copy templates and follow trends. We build custom brands and automated systems that make you impossible to ignore.
        </p>
      </div>
    </div>
  </div>
</section>
