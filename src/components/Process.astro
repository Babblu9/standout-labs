---
import ProcessFlow from './ProcessFlow.tsx';
---

<section id="process" class="w-full py-24 md:py-32 px-6 md:px-12 bg-white border-b border-[#E3E3DF]/50 scroll-mt-20">
  <div class="w-full max-w-7xl mx-auto flex flex-col gap-12">
    
    {/* Section Header */}
    <div class="flex flex-col gap-4">
      <span class="text-xs font-semibold uppercase tracking-[0.25em] text-brand-blue">
        Our Process
      </span>
      <h2 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight text-brand-black max-w-2xl leading-[0.95]">
        A roadmap from startup to scaled growth engine.
      </h2>
    </div>

    {/* Interactive React Flow Component */}
    <ProcessFlow client:load />

  </div>
</section>
