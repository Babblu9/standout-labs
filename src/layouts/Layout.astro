---
import '../styles/global.css';
import CustomCursor from '../components/CustomCursor.tsx';

interface Props {
  title?: string;
  description?: string;
  /** Path or absolute URL for <link rel="canonical">. Defaults to the current page. */
  canonical?: string;
  /** OG/Twitter share image (path or absolute URL). */
  ogImage?: string;
  /** Extra JSON-LD nodes to append to the graph (e.g. a Service or FAQPage). */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Set true on thin/utility pages you don't want indexed. */
  noindex?: boolean;
  /** Comma-separated keywords for this page. */
  keywords?: string;
}

const {
  title = "Digital Marketing & AI Branding Agency in Hyderabad | Standout Labs",
  description = "Standout Labs is a Hyderabad-based digital marketing and AI branding studio. We build brand identity, high-converting websites, performance marketing, content, and AI automation that make your business impossible to ignore.",
  canonical,
  ogImage = "/brand-assets/png/logo-2048.png",
  jsonLd,
  noindex = false,
  keywords = "digital marketing Hyderabad, digital marketing agency Hyderabad, AI branding, branding agency Hyderabad, web design Hyderabad, web development Hyderabad, SEO Hyderabad, local SEO, performance marketing, social media marketing Hyderabad, content marketing, AI automation, CRM automation, growth marketing, Standout Labs, StandoutLabs",
} = Astro.props;

const site = Astro.site ?? new URL("https://standoutlabs.in");
const canonicalURL = new URL(canonical ?? Astro.url.pathname, site);
const ogImageURL = new URL(ogImage, site);

// Organization / LocalBusiness graph — the backbone of local SEO for "digital marketing in Hyderabad".
const orgLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": `${site.origin}/#organization`,
  name: "Standout Labs",
  alternateName: "StandoutLabs",
  description,
  url: site.origin,
  logo: `${site.origin}/brand-assets/png/logo-2048.png`,
  image: ogImageURL.href,
  email: "info@standoutlabs.in",
  telephone: "+91-99634-91075",
  priceRange: "₹₹",
  areaServed: [
    { "@type": "City", name: "Hyderabad" },
    { "@type": "State", name: "Telangana" },
    { "@type": "Country", name: "India" },
  ],
  address: {
    "@type": "PostalAddress",
    addressLocality: "Hyderabad",
    addressRegion: "Telangana",
    addressCountry: "IN",
  },
  sameAs: [],
  knowsAbout: [
    "Digital Marketing",
    "AI Branding",
    "Brand Identity",
    "Web Design & Development",
    "Performance Marketing",
    "SEO",
    "Content Marketing",
    "Marketing Automation",
  ],
};

const websiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${site.origin}/#website`,
  url: site.origin,
  name: "Standout Labs",
  publisher: { "@id": `${site.origin}/#organization` },
  inLanguage: "en-IN",
};

const graph = [orgLd, websiteLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <meta name="theme-color" content="#111111" />
    <meta name="author" content="Standout Labs" />
    <meta name="geo.region" content="IN-TG" />
    <meta name="geo.placename" content="Hyderabad" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Standout Labs" />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL.href} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImageURL.href} />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(graph)} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-brand-bg text-brand-black antialiased selection:bg-brand-blue selection:text-brand-white">
    <!-- Premium custom cursor -->
    <CustomCursor client:load />

    <!-- Site Wrapper -->
    <div class="relative min-h-screen flex flex-col">
      <main class="flex-grow">
        <slot />
      </main>
    </div>

    <!-- Lenis Smooth Scroll Script -->
    <script>
      import Lenis from 'lenis';

      // Respect reduced-motion: skip smooth-scroll hijacking entirely.
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        const lenis = new Lenis({
          duration: 1.2,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,
          wheelMultiplier: 1,
          touchMultiplier: 2,
          infinite: false,
        });

        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);

        // Make lenis globally accessible for other animations (like scroll sync)
        window.lenisInstance = lenis;
      }

      // --- Hash-anchor navigation (Lenis suppresses native anchor jumps) ---
      const HEADER_OFFSET = -90; // account for the sticky header height

      function scrollToHash(hash: string, smooth = true) {
        if (!hash || hash === '#') return false;
        const el = document.querySelector(hash);
        if (!el) return false;
        if (window.lenisInstance) {
          window.lenisInstance.scrollTo(el, { offset: HEADER_OFFSET, duration: smooth ? 1.2 : 0 });
        } else {
          const y = el.getBoundingClientRect().top + window.scrollY + HEADER_OFFSET;
          window.scrollTo({ top: y, behavior: smooth ? 'smooth' : 'auto' });
        }
        return true;
      }

      // Intercept in-page anchor links, including "/#id" links when already on that page.
      document.addEventListener('click', (e) => {
        const link = (e.target as HTMLElement)?.closest('a');
        if (!link) return;
        const href = link.getAttribute('href') || '';
        const hashIndex = href.indexOf('#');
        if (hashIndex === -1) return;
        const path = href.slice(0, hashIndex);
        const hash = href.slice(hashIndex);
        // Only intercept when the target lives on the current page.
        const samePage = path === '' || path === '/' && window.location.pathname === '/' || path === window.location.pathname;
        if (!samePage) return;
        if (scrollToHash(hash)) {
          e.preventDefault();
          history.replaceState(null, '', hash);
        }
      });

      // On load, if the URL carries a hash (e.g. arrived from another page), scroll to it.
      if (window.location.hash) {
        window.addEventListener('load', () => setTimeout(() => scrollToHash(window.location.hash, false), 200));
      }
    </script>
  </body>
</html>

<style is:global>
  /* Define TS/JS interface for window.lenisInstance */
  declare global {
    interface Window {
      lenisInstance: any;
    }
  }
</style>
